{
  "rewrites": [
    { 
      "source": "/api/:path*", 
      "destination": "https://api.srkrlolo.in/api/:path*" 
    },
    { 
      "source": "/storage/:path*", 
      "destination": "https://api.srkrlolo.in/storage/:path*" 
    },
    { 
      "source": "/((?!api|storage).*)", 
      "destination": "/index.html" 
    }
  ]
}
